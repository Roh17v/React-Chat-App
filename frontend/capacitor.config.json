{
  "appId": "com.rohit.syncronus",
  "appName": "SyncronusChatApp",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "backgroundColor": "#000000",
    "allowMixedContent": false,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "CapacitorSQLite": {
      "androidIsEncryption": true,
      "androidBiometric": { "biometricAuth": false, "biometricTitle": "" },
      "iosIsEncryption": true,
      "iosKeychainPrefix": "syncronus_offline",
      "iosBiometric": { "biometricAuth": false, "biometricTitle": "" }
    }
  }
}
